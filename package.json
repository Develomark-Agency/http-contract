{
  "name": "http-contract",
  "version": "0.1.0",
  "description": "Type-safe HTTP client with a fluent endpoint builder, schema validation, and composable modes. Compatible with `\"better-result\"` and `\"@prodkit/op\".`",
  "type": "module",
  "module": "dist/index.mjs",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    },
    "./errors": {
      "import": "./dist/errors.mjs",
      "types": "./dist/errors.d.mts"
    },
    "./types": {
      "import": "./dist/types.mjs",
      "types": "./dist/types.d.mts"
    }
  },
  "scripts": {
    "build": "tsdown",
    "prepare": "tsdown"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "tsdown": "^0.22.4"
  },
  "peerDependencies": {
    "typescript": "^6"
  },
  "dependencies": {
    "@prodkit/op": "^0.2.2",
    "@standard-schema/spec": "^1.1.0",
    "better-result": "^2.9.2"
  }
}
