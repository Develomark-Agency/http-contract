{
  "name": "http-contract",
  "version": "0.1.0",
  "description": "Type-safe HTTP client with a fluent endpoint builder, schema validation, and composable modes. Compatible with `\"better-result\"` and `\"@prodkit/op\".`",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./errors": {
      "import": "./dist/errors.js",
      "types": "./dist/errors.d.ts"
    },
    "./types": {
      "import": "./dist/types.js",
      "types": "./dist/types.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "prepare": "tsc"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "typescript": "^6"
  },
  "dependencies": {
    "@prodkit/op": "^0.2.2",
    "@standard-schema/spec": "^1.1.0",
    "better-result": "^2.9.2"
  }
}
